# ─── Environment variable reference ─────────────────────────────────────────
# Copy this file to .env.development.local, .env.staging.local, etc.
# for local secret overrides that should not be committed to source control.
#
# Variables prefixed VITE_ are baked into the browser bundle at build time.
# Variables without VITE_ are server-side only (vite.config.js / Node scripts).
# ─────────────────────────────────────────────────────────────────────────────

# DEV ONLY — Vite proxy target (server-side, not exposed to the browser)
# Match the applicationUrl in POC.CustomerValidation.API/Properties/launchSettings.json (https profile)
DEV_API_TARGET=https://localhost:7124

# API base origin — leave empty to use the Vite proxy (dev) or Azure SWA
# linked-backend proxy (staging/prod).  Set to a full URL if the API lives
# on a separate domain: https://api.yourcompany.com
VITE_API_BASE_URL=

# Human-readable environment label shown in the browser console
VITE_APP_ENV=development

# Page title
VITE_APP_TITLE=DataValidation Portal
