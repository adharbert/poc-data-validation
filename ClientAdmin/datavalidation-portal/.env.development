# ─── Local development ───────────────────────────────────────────────────────
# Vite proxy target — the .NET API running locally.
# NOT exposed to the browser bundle (no VITE_ prefix).
DEV_API_TARGET=https://localhost:7124

# Leave empty: Vite proxy rewrites /api calls to DEV_API_TARGET above.
# Set to a full URL only if you want to bypass the proxy (e.g. a shared dev API).
VITE_API_BASE_URL=

VITE_APP_ENV=development
VITE_APP_TITLE=DataValidation Portal (Dev)
