# ─── Staging (Azure Static Web App) ─────────────────────────────────────────
# If using Azure SWA linked backend, leave VITE_API_BASE_URL empty —
# Azure SWA automatically proxies /api/* to the linked App Service.
#
# If the API is on a separate domain, set the full origin:
#   VITE_API_BASE_URL=https://api-staging.yourcompany.com
VITE_API_BASE_URL=

VITE_APP_ENV=staging
VITE_APP_TITLE=DataValidation Portal (Staging)
