{
  "Serilog": {
    "Application": "POC.CustomerValidation.API",
    "Sinks": {
      "InformationDb": { "Enabled": true },
      "ErrorDb": { "Enabled": true }
    },
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.MSSqlServer"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithThreadId"
    ]
  },
    "ConnectionStrings": {
        "DefaultConnection": "Data Source=HARBERT-PC;database=POC-data-validation;Integrated Security=True;Connect Timeout=30;Encrypt=False;Trust Server Certificate=False;Application Intent=ReadWrite;Multi Subnet Failover=False;Command Timeout=30",
        "LoggingConnection": "Data Source=HARBERT-PC;database=ApplicationLogs;Integrated Security=True;Connect Timeout=30;Encrypt=False;Trust Server Certificate=False"
    },

  "AllowedHosts": "*",

  "DashboardSettings": {
    "WarningDaysThreshold": 30
  },

  "ImportSettings": {
    "UploadPath": "uploads/imports"
  }
}

